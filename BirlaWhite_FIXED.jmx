        <TransactionController guiclass="TransactionControllerGui" testclass="TransactionController" testname="B-TC00 – Setup: Random Mobile Generator" enabled="true">
          <boolProp name="TransactionController.parent">true</boolProp>
          <boolProp name="TransactionController.includeTimers">false</boolProp>
        </TransactionController>
        <hashTree>
          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Generate Random Mobile No" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">String[] p = [&quot;6&quot;,&quot;7&quot;,&quot;8&quot;,&quot;9&quot;]
                            String first = p[(int)(Math.random()*4)]
                            String rest  = String.format(&quot;%09d&quot;,(long)(Math.random()*1_000_000_000L))
                            String mob   = first + rest
                            vars.put(&quot;MobileNo_1&quot;, mob)
                            vars.put(&quot;RAND_MOBILE&quot;, mob)
                            log.info(&quot;[TC00] Generated mobile: &quot; + mob)</stringProp>
          </JSR223Sampler>
          <hashTree/>
          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Generate Dynamic Profile Fields" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.util.UUID
                              String uid = UUID.randomUUID().toString().replace(&quot;-&quot;,&quot;&quot;).substring(0,8)
                              vars.put(&quot;INFL_NAME&quot;,  &quot;PerfUser_&quot; + uid)
                              vars.put(&quot;INFL_EMAIL&quot;, &quot;perf_&quot; + uid + &quot;@birlawhite.test&quot;)</stringProp>
          </JSR223Sampler>
          <hashTree/>
        </hashTree>
