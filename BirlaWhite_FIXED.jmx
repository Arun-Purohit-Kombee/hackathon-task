            <hashTree/>
            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Extract AUTHORIZATION" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">import groovy.json.JsonSlurper
                            try {
                            def resp = new JsonSlurper().parseText(prev.getResponseDataAsString())
                            def token = resp?.data?.token ?: resp?.data?.accessToken ?: resp?.data?.access_token ?: resp?.data?.authorization ?: resp?.accessToken ?: resp?.token ?: &quot;TOKEN_NOT_FOUND&quot;
                            vars.put(&quot;AUTHORIZATION&quot;, token.toString())
                            log.info(&quot;[Extractor] AUTHORIZATION = &quot; + token.toString())
                            } catch(Exception ex) {
                            vars.put(&quot;AUTHORIZATION&quot;, &quot;TOKEN_NOT_FOUND&quot;)
                            log.warn(&quot;[Extractor] AUTHORIZATION failed: &quot; + ex.getMessage())
                            }</stringProp>
            </JSR223PostProcessor>
            <hashTree/>
            <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Assert AUTHORIZATION extracted" enabled="true">
              <collectionProp name="Asserion.test_strings">
                <stringProp name="1023286998">NOT_FOUND</stringProp>
              </collectionProp>
              <stringProp name="Assertion.custom_message">AUTHORIZATION must not be NOT_FOUND – Bearer token must be extracted after login-verify</stringProp>
              <stringProp name="Assertion.test_field">Assertion.sample_label</stringProp>
              <stringProp name="Assertion.variable_name">AUTHORIZATION</stringProp>
              <boolProp name="Assertion.assume_success">false</boolProp>
              <intProp name="Asserion.test_type">6</intProp>
              <intProp name="Assertion.test_type">2</intProp>
            </ResponseAssertion>
            <hashTree/>
