          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Generate Random Mobile No" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">String[] p = [&quot;6&quot;,&quot;7&quot;,&quot;8&quot;,&quot;9&quot;]
                  String first = p[(int)(Math.random()*4)]
                  String rest  = String.format(&quot;%09d&quot;,(long)(Math.random()*1_000_000_000L))
                  String mob   = first + rest
                  vars.put(&quot;MobileNo_1&quot;, mob)
                  vars.put(&quot;RAND_MOBILE&quot;, mob)
                  log.info(&quot;[TC00] Generated mobile: &quot; + mob)</stringProp>
          </JSR223Sampler>
