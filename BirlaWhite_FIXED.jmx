        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Cleanup – Delete Old Result Files">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">// -------------------------------------------------------
// Auto-cleanup: delete old .jtl result files so JMeter
// does not show &quot;file already exists&quot; warning popups.
// Also ensures the results/ folder exists before the run.
// -------------------------------------------------------
import java.nio.file.Files
import java.nio.file.Paths

// Resolve the results/ folder relative to the JMX working directory
def resultsDir = new File(&quot;results&quot;)
if (!resultsDir.exists()) {
    resultsDir.mkdirs()
    log.info(&quot;[Cleanup] Created directory: &quot; + resultsDir.absolutePath)
}

// List of .jtl result files to delete before each run
def filesToDelete = [
    &quot;results/summary_report.jtl&quot;,
    &quot;results/aggregate_report.jtl&quot;,
    &quot;results/response_time.jtl&quot;,
    &quot;results/errors_only.jtl&quot;
]

filesToDelete.each { path -&gt;
    def f = new File(path)
    if (f.exists()) {
        f.delete()
        log.info(&quot;[Cleanup] Deleted old result file: &quot; + f.absolutePath)
    }
}
log.info(&quot;[Cleanup] Result file cleanup complete.&quot;)</stringProp>
        </JSR223Sampler>
