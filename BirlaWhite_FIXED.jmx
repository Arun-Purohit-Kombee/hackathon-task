    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="Birla White – Influencer Platform Advanced Performance Suite">
      <stringProp name="TestPlan.comments">Collection: Birla White - Runner | Generated: 2026-03-14
        Scenarios: A-Normal Load | B-Spike | B2-Recovery | C-Soak
        Flow: initiate-signup → verify-otp → complete-signup → app-login → app-login-verify → Authenticated APIs
        Extractors: JSR223/Groovy JsonSlurper (replaces JSONPathExtractor to fix CannotResolveClassException)
        Data: data/users.csv | Results: results/</stringProp>
      <boolProp name="TestPlan.tearDown_on_shutdown">true</boolProp>
