        <hashTree>
          <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="POST /initiate-influencer-signup" enabled="true">
            <stringProp name="HTTPSampler.path">/api/v1/initiate-influencer-signup</stringProp>
