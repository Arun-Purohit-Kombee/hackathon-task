            <hashTree/>
            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Extract MobileNo_1" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">import groovy.json.JsonSlurper
                                  try {
                                  def resp = new JsonSlurper().parseText(prev.getResponseDataAsString())
                                  def val = resp?.data?.mobileNo ?: &quot;MOBILE_NOT_FOUND&quot;
                                  vars.put(&quot;MobileNo_1&quot;, val.toString())
                                  log.info(&quot;[Extractor] MobileNo_1 = &quot; + val.toString())
                                  } catch(Exception ex) {
                                  vars.put(&quot;MobileNo_1&quot;, &quot;MOBILE_NOT_FOUND&quot;)
                                  log.warn(&quot;[Extractor] MobileNo_1 failed: &quot; + ex.getMessage())
                                  }</stringProp>
            </JSR223PostProcessor>
            <hashTree/>
            <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Assert MobileNo_1 extracted" enabled="true">
              <collectionProp name="Asserion.test_strings">
                <stringProp name="1023286998">NOT_FOUND</stringProp>
              </collectionProp>
              <stringProp name="Assertion.custom_message">MobileNo_1 must not be NOT_FOUND – mobileNo must be in initiate-signup response</stringProp>
              <stringProp name="Assertion.test_field">Assertion.sample_label</stringProp>
              <stringProp name="Assertion.variable_name">MobileNo_1</stringProp>
              <boolProp name="Assertion.assume_success">false</boolProp>
